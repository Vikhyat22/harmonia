# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_bot_token_here
CLIENT_ID=your_discord_client_id
GUILD_ID=
PORT=3000

# Lavalink Server (Music Playback)
LAVALINK_HOSTS=localhost:2333
LAVALINK_AUTH=yourlavalinkpassword
LAVALINK_SECURE=false
SEARCH_ENGINE=ytmsearch
MUSIC_TEXT_SEARCH_SOURCES=youtube_music,youtube,spotify
SPOTIFY_PREFER_ANONYMOUS_TOKEN=false
SPOTIFY_TOKEN_ENDPOINT=

# Optional Settings
ENABLE_MESSAGE_CONTENT_INTENT=false
ENABLE_HTTP_SERVER=true
DATA_DIR=./data
TTS_PROVIDER_ORDER=edge,piper
PIPER_INSTALL_DIR=./vendor/piper
PIPER_BINARY_URL=https://github.com/rhasspy/piper/releases/download/2023.11.14-2/piper_linux_x86_64.tar.gz
PIPER_PATH=./vendor/piper/piper
PIPER_MODEL_DIR=./vendor/piper/models
PIPER_MODEL_MAP=
PIPER_MODEL_MANIFEST={"en-US":{"modelUrl":"https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/lessac/medium/en_US-lessac-medium.onnx","configUrl":"https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/lessac/medium/en_US-lessac-medium.onnx.json"},"hi-IN":{"modelUrl":"https://huggingface.co/rhasspy/piper-voices/resolve/main/hi/hi_IN/priyamvada/medium/hi_IN-priyamvada-medium.onnx","configUrl":"https://huggingface.co/rhasspy/piper-voices/resolve/main/hi/hi_IN/priyamvada/medium/hi_IN-priyamvada-medium.onnx.json"},"te-IN":{"modelUrl":"https://huggingface.co/rhasspy/piper-voices/resolve/main/te/te_IN/maya/medium/te_IN-maya-medium.onnx","configUrl":"https://huggingface.co/rhasspy/piper-voices/resolve/main/te/te_IN/maya/medium/te_IN-maya-medium.onnx.json"},"ml-IN":{"modelUrl":"https://huggingface.co/rhasspy/piper-voices/resolve/main/ml/ml_IN/meera/medium/ml_IN-meera-medium.onnx","configUrl":"https://huggingface.co/rhasspy/piper-voices/resolve/main/ml/ml_IN/meera/medium/ml_IN-meera-medium.onnx.json"}}
DEFAULT_VOICE=en-US
MAX_TEXT_LENGTH=5000
